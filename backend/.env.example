# ─────────────────────────────────────────────────────
# ContractorOS Pro — Backend Environment
# Stack: Vercel (frontend) + Supabase (DB) + Render (API)
# ─────────────────────────────────────────────────────

# ── DATABASE (Supabase) ───────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
# Use the "Transaction" pooler URI (port 6543)
# IMPORTANT: Replace [YOUR-PASSWORD] with your Supabase project password
DATABASE_URL="postgresql://postgres.nwfaoxhimjuyrxfnygwf:RomeroAcevedo8075@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ── JWT AUTH ──────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN="7d"

# ── SERVER ────────────────────────────────────────────
PORT=4000
NODE_ENV="production"

# ── CORS (Vercel frontend URL — no trailing slash) ───
# Comma-separate multiple: "https://app.example.com,http://localhost:3000"
FRONTEND_URL="https://contractor-os.vercel.app"

# ── SMTP (optional — configure in Company Setup UI) ──
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
